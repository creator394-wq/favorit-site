# Скопируйте в .env и заполните. Файл .env НЕ коммитится (.gitignore: .env*).

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Разрешённые Telegram user id через запятую (allowlist админов).
# Узнать свой id: напишите @userinfobot или @getmyid_bot.
TELEGRAM_ADMIN_IDS=

# Vercel Deploy Hook URL (Project Settings → Git → Deploy Hooks).
# Нужен для /publish. Если пусто — /publish вернёт понятную ошибку.
VERCEL_DEPLOY_HOOK_URL=

# E8 — порт локального bot-API приёма заявок (POST /api/lead). По умолчанию 8787.
LEAD_API_PORT=8787

# E8.1 — override URL API заявок для формы (читается Vite на сборке).
# Прод (Vercel): оставьте ПУСТЫМ — форма шлёт на relative /api/lead (serverless function).
# Локально с bot-API: VITE_LEAD_API_URL=http://localhost:8787/api/lead
VITE_LEAD_API_URL=

# E23 — Google Analytics 4 (для /analytics, /top_pages, /sources).
# Если переменных нет — трафик-команды честно сообщают «GA4 не подключён»,
# а /conversion и заявки работают всегда (данные из CRM).
# 1) ID ресурса GA4 (Admin → Property Settings → Property ID, только цифры):
GA4_PROPERTY_ID=
# 2a) Сервис-аккаунт с ролью Viewer в GA4 (рекомендуется). PRIVATE_KEY в одну
#     строку, переводы строк как \n. Email сервис-аккаунта добавьте в GA4 Access.
GA_CLIENT_EMAIL=
GA_PRIVATE_KEY=
# 2b) ИЛИ готовый OAuth access token (если получаете его извне):
GA4_ACCESS_TOKEN=
